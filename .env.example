# -----------------------------------------------------------------------------
# Portal Hiruko credentials
# -----------------------------------------------------------------------------
# Never commit real values. Copy this file to `.env` and fill it in locally.
PORTAL_URL=https://prodiagnosticotest.hiruko.com.co
PORTAL_USER=your-username-here
PORTAL_PASSWORD=your-password-here

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=ashtronic
POSTGRES_PASSWORD=ashtronic
POSTGRES_DB=ashtronic_rpa
# Host `db` is the service name inside docker-compose
DATABASE_URL=postgresql+asyncpg://ashtronic:ashtronic@db:5432/ashtronic_rpa

# -----------------------------------------------------------------------------
# Selenium (standalone-chrome container)
# -----------------------------------------------------------------------------
# Host `selenium` is the service name inside docker-compose
SELENIUM_HUB_URL=http://selenium:4444/wd/hub
SELENIUM_TIMEOUT=30

# Retries for transient bot failures (portal slow, flaky overlay).
# attempts=1 means no retry; 3 = up to 2 retries after the first call.
BOT_RETRY_ATTEMPTS=3
BOT_RETRY_BACKOFF_SECONDS=2.0

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Set to true to emit JSON-formatted logs (one line per record, includes request_id).
LOG_JSON=true
SCREENSHOTS_DIR=/app/artifacts/screenshots
